{
  "name": "type-imagereader",
  "version": "1.0.0",
  "type": "module",
  "main": "./app.ts",
  "description": "Self-hosted web app for browsing local image and comic collections, with PostgreSQL-backed indexing and live filesystem sync",
  "scripts": {
    "prebuild": "npm run lint",
    "build:client": "esbuild app=public/scripts/app/main.ts slideshow=public/scripts/slideshow/main.ts --bundle --minify --target=es2024 --format=iife --outdir=dist/scripts --sourcemap",
    "build:sass": "sass public/stylesheets:dist/stylesheets --style=compressed",
    "build": "run-p build:client build:sass typecheck",
    "typecheck": "tsc --build tsconfig.json",
    "pretty": "prettier . --write --log-level=warn",
    "prelint": "npm run pretty",
    "lint": "eslint .",
    "start": "DEBUG='type-imagereader:*' tsx .",
    "pretest": "npm run lint && npm run typecheck",
    "test": "vitest run --coverage",
    "pretest:detailed": "npm run lint && npm run typecheck",
    "test:detailed": "vitest run --coverage --reporter=verbose",
    "test:watch": "vitest --coverage",
    "knex": "tsx ./node_modules/knex/bin/cli.js --knexfile knexfile.json",
    "predev": "npm run build",
    "dev": "DEBUG='type-imagereader:*' tsx .",
    "predev:serve": "npm run build",
    "dev:serve": "DEBUG='type-imagereader:*' SKIP_SYNC=1 tsx .",
    "predev:watch": "npm run typecheck",
    "dev:watch": "DEBUG='type-imagereader:*' SKIP_SERVE=1 tsx .",
    "predev:scan": "npm run typecheck",
    "dev:scan": "DEBUG='type-imagereader:*' SKIP_SERVE=1 ONESHOT=1 tsx ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AccaliaDeElementia/type-imagereader.git"
  },
  "author": "Accalia Elementia",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/AccaliaDeElementia/type-imagereader/issues"
  },
  "homepage": "https://github.com/AccaliaDeElementia/type-imagereader#readme",
  "imports": {
    "#testutils/*.js": "./testutils/*.ts",
    "#public/*.js": "./public/*.ts",
    "#routes/*.js": "./routes/*.ts",
    "#utils/*.js": "./utils/*.ts",
    "#sync/*.js": "./sync/*.ts",
    "#contracts/*.js": "./contracts/*.ts",
    "#server.js": "./server.ts",
    "#app.js": "./app.ts"
  },
  "dependencies": {
    "@parcel/watcher": "^2.5.6",
    "cookie-parser": "^1.4.7",
    "debug": "^4.4.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "knex": "^3.2.10",
    "morgan": "^1.10.1",
    "pg": "^8.18.0",
    "pg-copy-streams": "^7.0.0",
    "pug": "^3.0.3",
    "serve-favicon": "^2.5.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "words-to-numbers": "^1.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.3",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.7.0",
    "@types/pg-copy-streams": "^1.2.5",
    "@types/pug": "^2.0.10",
    "@types/serve-favicon": "^2.5.7",
    "@types/sinon": "^21.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-istanbul": "^4.1.6",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.2",
    "eslint-config-love": "^154.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "sinon": "21.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.10.0"
  }
}
