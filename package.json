{
  "name": "type-imagereader",
  "version": "1.0.0",
  "description": "A typscript powered web based image and comic reader pulling from local files",
  "scripts": {
    "prebuild": "npm run lint",
    "build:client": "esbuild app=public/scripts/app/index.ts slideshow=public/scripts/slideshow/index.ts --bundle --minify --target=es2024 --format=iife --outdir=dist/scripts --sourcemap",
    "build:sass": "sass public/stylesheets:dist/stylesheets --style=compressed",
    "build": "npm run build:client && npm run build:sass && tsc --build tsconfig.json",
    "pretty": "prettier . --write",
    "prettyCheck": "prettier . --write --log-level=warn",
    "prelint": "npm run prettyCheck",
    "lint": "eslint .",
    "lintfix": "eslint . --fix",
    "start": "DEBUG='type-imagereader:*' ts-node .",
    "pretest": "npm run build",
    "test": "c8 mocha",
    "knex": "knex --knexfile knexfile.json",
    "predev": "npm run build",
    "dev": "DEBUG='type-imagereader:*' SKIP_SYNC=1 ts-node .",
    "scan": "DEBUG='type-imagereader:*' SKIP_SERVE=1 ts-node ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AccaliaDeElementia/type-imagereader.git"
  },
  "author": "Accalia Elementia",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/AccaliaDeElementia/type-imagereader/issues"
  },
  "homepage": "https://github.com/AccaliaDeElementia/type-imagereader#readme",
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "debug": "^4.4.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "knex": "^3.1.0",
    "morgan": "^1.10.1",
    "pg": "^8.18.0",
    "pug": "^3.0.3",
    "serve-favicon": "^2.5.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "words-to-numbers": "^1.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/chai": "^5.2.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.1",
    "@types/mocha": "^10.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.2.3",
    "@types/pug": "^2.0.10",
    "@types/serve-favicon": "^2.5.7",
    "@types/sinon": "^21.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.2",
    "eslint-config-love": "^151.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "globals": "^17.3.0",
    "jsdom": "^29.0.1",
    "mocha": "^12.0.0-beta-10",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "sinon": "^21.0.1",
    "source-map-support": "^0.5.21",
    "typescript-eslint": "^8.56.0"
  },
  "c8": {
    "check-coverage": true,
    "lines": 80,
    "statements": 80,
    "functions": 80,
    "branches": 80,
    "include": [
      "**/*.ts",
      "utils/*.ts"
    ],
    "exclude": [
      "**/*.spec.ts",
      "knexfile.ts",
      "test.ts",
      "migrations/**"
    ],
    "reporter": [
      "lcov",
      "text",
      "text-summary"
    ],
    "all": true
  }
}
